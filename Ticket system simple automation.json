    {
      "parameters": {
        "jsCode": "// Map problem types to IT helpers\nconst itHelpers = {\n  \"Hardware problem\": \"hardware_team@company.com\",\n  \"Network problem\": \"dodomaged4@yahoo.com\",\n  \"Software problem\": \"software_team@company.com\",\n  \"Account/Access problem\": \"accounts_team@company.com\",\n  \"Peripheral problem\": \"peripherals_team@company.com\",\n  \"Email/Communication problem\": \"email_team@company.com\",\n  \"Security problem\": \"security_team@company.com\",\n  \"Other problem\": \"general_it@company.com\"\n};\n\n// Example inputs (replace with actual AI output + user message)\nconst aiOutput = $input.first().json.content; // <-- classification result from AI node\nconst userMessage = $('Telegram Trigger').first().json.message.text;\n\n// Format current date/time as dd/mm/yyyy hh:mm in GMT+2 (Cairo)\nfunction formatDateGMT2(date) {\n  // Convert to Cairo timezone\n  const options = {\n    timeZone: \"Africa/Cairo\",\n    day: \"2-digit\",\n    month: \"2-digit\",\n    year: \"numeric\",\n    hour: \"2-digit\",\n    minute: \"2-digit\",\n    hour12: false\n  };\n  const formatter = new Intl.DateTimeFormat(\"en-GB\", options);\n  return formatter.format(date).replace(\",\", \"\");\n}\n\nconst currentDate = formatDateGMT2(new Date());\n\n// Build array of objects for n8n\nreturn [\n  {\n    problemType: aiOutput,\n    assignedHelper: itHelpers[aiOutput] || itHelpers[\"Other problem\"],\n    ticketMessage: userMessage,\n    date: currentDate,\n    status: \"pending\"\n  }\n];\n"
      },
